# Copie este arquivo para .env (que é ignorado pelo Git) e preencha com suas credenciais reais.
# NUNCA commite o .env — ele contém segredos (connection string com senha, API keys).

# Connection string do PostgreSQL (Supabase: Project Settings → Database → Connection string).
# Use a connection pooling (porta 6543, modo "Transaction") para scripts curtos como este pipeline.
# Formato: postgresql://usuario:senha@host:porta/banco
DATABASE_URL=postgresql://postgres.xxxxxxxx:SENHA_AQUI@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# API key da OpenAI (usada na Etapa 4 — classificação por embeddings / resumo executivo).
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
